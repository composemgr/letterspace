# Letterspace Email Newsletter - Environment Variables
# Copy to app.env and customize

# Timezone
TZ=America/New_York

# Host settings
BASE_HOST_NAME=letterspace.example.com

# Database (PostgreSQL)
DB_CREATE_DATABASE_NAME=letterspace
DB_USER_NAME=letterspaceuser
DB_USER_PASS=changeme_db_password

# Application secret (JWT signing key, min 32 chars)
APP_SECRET_KEY=changeme_secret_key_min_32_chars
